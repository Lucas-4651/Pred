<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VFL Dashboard - Statistiques d'apprentissage</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/dashboard.css">
    
    <style>
        .navbar-brand {
            font-weight: 700;
            background: linear-gradient(135deg, #FC3D32, #007E3A);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .last-update {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.7);
        }
        
        .refresh-btn {
            cursor: pointer;
            transition: transform 0.3s ease;
        }
        
        .refresh-btn:hover {
            transform: rotate(180deg);
            color: var(--madagascar-green);
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand">
                <i class="fas fa-brain me-2"></i>
                VFL Learning Dashboard
            </span>
            <div class="d-flex align-items-center gap-3">
                <span class="last-update" id="lastUpdate"></span>
                <i class="fas fa-sync-alt refresh-btn text-white" id="refreshBtn"></i>
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4">
        <!-- KPIs principaux -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-chart-line"></i>
                        <h3>Précision globale</h3>
                    </div>
                    <div class="main-metric">
                        <div class="value" id="accuracyValue">0%</div>
                        <div class="label">Vainqueurs corrects</div>
                        <div class="trend up" id="accuracyTrend">
                            <i class="fas fa-arrow-up"></i> vs hier
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between">
                            <span>Total prédictions</span>
                            <strong id="totalPredictions">0</strong>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-bullseye"></i>
                        <h3>Scores exacts</h3>
                    </div>
                    <div class="main-metric">
                        <div class="value" id="exactMatchValue">0%</div>
                        <div class="label">Score parfait</div>
                    </div>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between">
                            <span>À 1 but près</span>
                            <strong id="withinOneValue">0%</strong>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-futbol"></i>
                        <h3>Précision buts</h3>
                    </div>
                    <div class="main-metric">
                        <div class="value" id="goalsExactValue">0%</div>
                        <div class="label">Buts exacts</div>
                    </div>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between">
                            <span>À 1 but près</span>
                            <strong id="goalsWithinValue">0%</strong>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <span>Biais</span>
                            <strong id="goalsBias" class="text-warning">0</strong>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-scale-balanced"></i>
                        <h3>Échantillon</h3>
                    </div>
                    <div class="main-metric">
                        <div class="value" id="sampleSize">0</div>
                        <div class="label">Matchs analysés</div>
                    </div>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between">
                            <span>Avantage domicile</span>
                            <strong id="homeAdvantage">0%</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Poids des modèles et distribution -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-weight-hanging"></i>
                        <h3>Poids des modèles</h3>
                    </div>
                    <div class="progress-wrapper" id="weightsContainer">
                        <!-- Rempli par JS -->
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-chart-pie"></i>
                        <h3>Distribution des buts</h3>
                    </div>
                    <div class="mini-chart" id="goalRangeChart">
                        <!-- Rempli par JS -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Scores les plus fréquents -->
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-star"></i>
                        <h3>Scores les plus fréquents</h3>
                    </div>
                    <div class="score-grid" id="commonScores">
                        <!-- Rempli par JS -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Calibration par confiance -->
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="stats-card">
                    <div class="card-header-custom">
                        <i class="fas fa-sliders"></i>
                        <h3>Calibration par niveau de confiance</h3>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Confiance</th>
                                    <th>Précision vainqueur</th>
                                    <th>Score exact</th>
                                    <th>Buts exacts</th>
                                    <th>Échantillon</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody id="calibrationTable">
                                <!-- Rempli par JS -->
                            </tbody>
                        </table>
                    </div>
                    <div class="alert-insight mt-3" id="calibrationInsight">
                        <!-- Insights dynamiques -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Insights et recommandations -->
        <div class="row">
            <div class="col-12">
                <div class="stats-card bg-dark text-white">
                    <div class="card-header-custom">
                        <i class="fas fa-lightbulb text-warning"></i>
                        <h3 class="text-white">Insights & Recommandations</h3>
                    </div>
                    <div id="insights">
                        <!-- Rempli par JS -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>